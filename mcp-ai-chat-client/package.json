{
  "name": "mcp-ai-chat-client",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "prettier --check . && ng lint",
    "lint-fix": "prettier --list-different --write . && ng lint --fix",
    "format": "prettier --list-different --write .",
    "show-deps-updates": "npm-check-updates",
    "update-deps": "npm-check-updates -u && npm install",
    "ci": "npm run lint && npm run build && npm run test"
  },
  "prettier": {
    "bracketSameLine": true,
    "printWidth": 100,
    "singleQuote": true,
    "trailingComma": "none",
    "useTabs": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "type": "module",
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/material": "^21.2.4",
    "@angular/platform-browser": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5",
    "marked-highlight": "^2.2.3",
    "ollama": "^0.6.3",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.6",
    "@eslint/css": "^1.0.0",
    "angular-eslint": "21.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.0.1",
    "npm-check-updates": "^19.6.6",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "^4.1.2"
  }
}
