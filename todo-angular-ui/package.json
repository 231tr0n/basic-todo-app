{
	"name": "todo-angular-ui",
	"version": "0.0.0",
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build",
		"watch": "ng build --watch --configuration development",
		"test": "ng test",
		"lint": "prettier --check . && ng lint",
		"lint-fix": "prettier --list-different --write . && ng lint --fix",
		"format": "prettier --list-different --write .",
		"show-deps-updates": "npm-check-updates",
		"update-deps": "npm-check-updates -u && npm install",
		"ci": "npm run lint && npm run build && npm run test"
	},
	"prettier": {
		"bracketSameLine": true,
		"printWidth": 100,
		"singleQuote": true,
		"trailingComma": "none",
		"useTabs": true,
		"overrides": [
			{
				"files": "*.html",
				"options": {
					"parser": "angular"
				}
			}
		]
	},
	"type": "module",
	"private": true,
	"packageManager": "npm@11.11.1",
	"dependencies": {
		"@angular/cdk": "^21.2.2",
		"@angular/common": "^21.2.4",
		"@angular/compiler": "^21.2.4",
		"@angular/core": "^21.2.4",
		"@angular/forms": "^21.2.4",
		"@angular/material": "^21.2.2",
		"@angular/platform-browser": "^21.2.4",
		"@angular/router": "^21.2.4",
		"rxjs": "~7.8.2",
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@angular/build": "^21.2.2",
		"@angular/cli": "^21.2.2",
		"@angular/compiler-cli": "^21.2.4",
		"@eslint/css": "^1.0.0",
		"angular-eslint": "21.3.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"jsdom": "^29.0.0",
		"npm-check-updates": "^19.6.3",
		"prettier": "^3.8.1",
		"typescript": "~5.9.3",
		"typescript-eslint": "8.57.0",
		"vitest": "^4.1.0"
	}
}
